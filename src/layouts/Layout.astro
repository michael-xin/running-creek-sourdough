---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Running Creek Sourdough - Artisan sourdough bread from our home bakery." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
	</head>
	<body>
    <nav class="container">
      <div class="logo">Running Creek Sourdough</div>
      <ul>
        <li><a href="#about">Our Story</a></li>
        <li><a href="#bread">The Bread</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
		<slot />
    <footer>
      <div class="container text-center">
        <p>&copy; {new Date().getFullYear()} Running Creek Sourdough. Handcrafted in Australia.</p>
      </div>
    </footer>
	</body>
</html>
<style is:global>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--color-dark);
  }
  nav ul {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    text-decoration: none;
    color: var(--color-text);
    font-weight: 600;
  }
  nav a:hover {
    color: var(--color-golden);
  }
  footer {
    padding: 3rem 0;
    background: var(--color-dark);
    color: var(--color-flour);
    margin-top: 4rem;
  }
</style>
