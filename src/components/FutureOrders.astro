  h2 {
    font-size: 2rem;
    color: var(--color-crust);
  }
  .email-link {
    display: inline-block;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-top: 1rem;
    text-decoration: none;
    border-bottom: 2px solid var(--color-golden);
  }
  .email-link:hover {
    color: var(--color-golden);
  }
</style>
